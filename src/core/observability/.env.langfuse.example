# Local development only. Copy to .env.langfuse and replace before sharing a host.

# Python SDK auth: LangfuseTracer() auto-loads these to publish traces.
# Must match the LANGFUSE_INIT_PROJECT_* values below.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-nextauth-secret-change-me
SALT=local-salt-change-me
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TELEMETRY_ENABLED=false

POSTGRES_PASSWORD=postgres_local
DATABASE_URL=postgresql://postgres:postgres_local@postgres:5432/postgres
CLICKHOUSE_PASSWORD=clickhouse_local
REDIS_AUTH=redis_local
MINIO_ROOT_PASSWORD=minio_local
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=minio_local
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=minio_local
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=minio_local

LANGFUSE_INIT_PROJECT_ID=local-project
LANGFUSE_INIT_PROJECT_NAME=Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-local


LANGFUSE_INIT_USER_EMAIL=admin@local.host
LANGFUSE_INIT_USER_PASSWORD=password123
LANGFUSE_INIT_USER_NAME="Local Admin"
LANGFUSE_INIT_ORG_ID=local_org
LANGFUSE_INIT_ORG_NAME="Local Org"